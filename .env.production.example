# SkeinRank production-like Docker Compose example.
# Copy to .env, replace every CHANGE_ME value, and review docs/deployment/security.md.
# Never commit your real .env file.

TZ=UTC
SKEINRANK_ENV=production
SKEINRANK_GOVERNANCE_API_ENV=production

# Bind API/UI to localhost by default. Put a reverse proxy or VPN in front.
GOVERNANCE_API_PORT=8010
UI_PORT=5173
PUBLIC_UI_ORIGIN=https://skeinrank.example.com
VITE_SKEINRANK_GOVERNANCE_API_URL=https://skeinrank-api.example.com

# PostgreSQL is internal to the Compose network in docker-compose.prod.yml.
POSTGRES_DB=skeinrank
POSTGRES_USER=skeinrank
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# RabbitMQ is internal to the Compose network in docker-compose.prod.yml.
RABBITMQ_DEFAULT_USER=skeinrank
RABBITMQ_DEFAULT_PASS=CHANGE_ME_STRONG_RABBITMQ_PASSWORD

# Governance API security.
SKEINRANK_GOVERNANCE_API_AUTH_ENABLED=true
SKEINRANK_GOVERNANCE_API_BOOTSTRAP_ADMIN=true
SKEINRANK_GOVERNANCE_API_ADMIN_USERNAME=admin
SKEINRANK_GOVERNANCE_API_ADMIN_PASSWORD=CHANGE_ME_STRONG_BOOTSTRAP_ADMIN_PASSWORD
SKEINRANK_GOVERNANCE_API_ADMIN_DISPLAY_NAME=SkeinRank Admin
SKEINRANK_GOVERNANCE_API_CORS_ORIGINS=https://skeinrank.example.com
SKEINRANK_GOVERNANCE_API_TOKEN_TTL_HOURS=12
SKEINRANK_GOVERNANCE_API_PRODUCTION_SECURITY_ENABLED=true

# Runtime jobs.
SKEINRANK_GOVERNANCE_API_ENRICHMENT_JOBS_BACKEND=celery
SKEINRANK_GOVERNANCE_API_CELERY_TASK_QUEUE=skeinrank.enrichment
SKEINRANK_GOVERNANCE_API_ENRICHMENT_CHUNK_SIZE=500

# External Elasticsearch / OpenSearch endpoint.
# Prefer TLS and credentials/API key in production.
SKEINRANK_GOVERNANCE_API_ELASTICSEARCH_URL=https://elasticsearch.example.com:9200
SKEINRANK_GOVERNANCE_API_ELASTICSEARCH_USERNAME=CHANGE_ME_ES_USERNAME
SKEINRANK_GOVERNANCE_API_ELASTICSEARCH_PASSWORD=CHANGE_ME_ES_PASSWORD
# Alternative:
# SKEINRANK_GOVERNANCE_API_ELASTICSEARCH_API_KEY=CHANGE_ME_ES_API_KEY
SKEINRANK_GOVERNANCE_API_ELASTICSEARCH_TIMEOUT_SECONDS=10

# SkeinRank production-oriented Docker Compose environment.
# Copy to .env and replace every CHANGE_ME value before running docker-compose.prod.yml.
# Do not commit real secrets.

COMPOSE_PROJECT_NAME=skeinrank-prod
TZ=UTC

# Local bind ports for the API/UI/observability surfaces.
# Keep these on 127.0.0.1 in docker-compose.prod.yml and expose via a reverse proxy/VPN.
GOVERNANCE_API_PORT=8010
UI_PORT=5173
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Docker json-file log rotation.
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5

# PostgreSQL source-of-truth state.
POSTGRES_DB=skeinrank
POSTGRES_USER=skeinrank
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# RabbitMQ broker for Celery enrichment jobs.
RABBITMQ_DEFAULT_USER=skeinrank
RABBITMQ_DEFAULT_PASS=CHANGE_ME_STRONG_RABBITMQ_PASSWORD

# Governance API production guardrails.
SKEINRANK_ENV=production
SKEINRANK_GOVERNANCE_API_ENV=production
SKEINRANK_GOVERNANCE_API_AUTH_ENABLED=true
SKEINRANK_GOVERNANCE_API_BOOTSTRAP_ADMIN=true
SKEINRANK_GOVERNANCE_API_ADMIN_USERNAME=admin
SKEINRANK_GOVERNANCE_API_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
SKEINRANK_GOVERNANCE_API_ADMIN_DISPLAY_NAME=SkeinRank Admin
SKEINRANK_GOVERNANCE_API_TOKEN_TTL_HOURS=12
SKEINRANK_GOVERNANCE_API_PRODUCTION_SECURITY_ENABLED=true
SKEINRANK_GOVERNANCE_API_CORS_ORIGINS=https://skeinrank.example.com

# UI -> API URL as seen by the browser.
VITE_SKEINRANK_GOVERNANCE_API_URL=https://skeinrank-api.example.com

# Optional Elasticsearch/OpenSearch endpoint used by bindings, enrichment and runtime search.
# Leave empty for a first production-ish Compose smoke test. Set it when you want
# /readyz and runtime search to validate an external search backend.
SKEINRANK_GOVERNANCE_API_ELASTICSEARCH_URL=
SKEINRANK_GOVERNANCE_API_ELASTICSEARCH_USERNAME=
SKEINRANK_GOVERNANCE_API_ELASTICSEARCH_PASSWORD=
SKEINRANK_GOVERNANCE_API_ELASTICSEARCH_API_KEY=
SKEINRANK_GOVERNANCE_API_ELASTICSEARCH_TIMEOUT_SECONDS=10

# Async enrichment worker.
SKEINRANK_GOVERNANCE_API_ENRICHMENT_JOBS_BACKEND=celery
SKEINRANK_GOVERNANCE_API_CELERY_TASK_QUEUE=skeinrank.enrichment
SKEINRANK_GOVERNANCE_API_ENRICHMENT_CHUNK_SIZE=500

# Observability defaults.
SKEINRANK_GOVERNANCE_API_OBSERVABILITY_ENABLED=true
SKEINRANK_GOVERNANCE_API_LOG_FORMAT=json
SKEINRANK_GOVERNANCE_API_LOG_LEVEL=info
SKEINRANK_GOVERNANCE_API_ACCESS_LOG_ENABLED=true
SKEINRANK_GOVERNANCE_API_REQUEST_ID_HEADER=X-Request-ID
SKEINRANK_GOVERNANCE_API_METRICS_ENABLED=true
SKEINRANK_GOVERNANCE_API_METRICS_PATH=/metrics
SKEINRANK_GOVERNANCE_API_TRACING_ENABLED=false
SKEINRANK_GOVERNANCE_API_OTEL_SERVICE_NAME=skeinrank-governance-api
SKEINRANK_GOVERNANCE_API_OTEL_TRACES_EXPORTER=none
SKEINRANK_GOVERNANCE_API_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
SKEINRANK_GOVERNANCE_API_OTEL_SAMPLING_RATIO=1.0
SKEINRANK_GOVERNANCE_API_OTEL_CAPTURE_QUERY_TEXT=false

# Optional production observability profile.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD

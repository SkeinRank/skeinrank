# Copy this file outside Git before running the OpenRouter alias scout service.
# Never commit real OpenRouter or SkeinRank tokens.

SKEINRANK_AGENT_API_URL=http://governance-api:8010
SKEINRANK_AGENT_ROLE=contributor
SKEINRANK_AGENT_API_TOKEN=CHANGE_ME_AGENT_CONTRIBUTOR_TOKEN

OPENROUTER_API_KEY=CHANGE_ME_OPENROUTER_KEY
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# Keep proposal submission disabled in the reference deployment recipe.
# The agent can prepare reports; governed submission is enabled only in a later policy path.
SKEINRANK_AGENT_SUBMIT_PROPOSALS=false

# SkeinRank OpenRouter agent full Docker Compose demo.
# Copy this file before use if you want to override values.
# Never commit real OpenRouter or SkeinRank tokens.

# Local demo ports inherited by docker-compose.dev.yml.
GOVERNANCE_API_PORT=8010
ELASTICSEARCH_PORT=19200
POSTGRES_PORT=15432
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
UI_PORT=5173

# Governance API dev defaults.
SKEINRANK_GOVERNANCE_API_AUTH_ENABLED=true
SKEINRANK_GOVERNANCE_API_BOOTSTRAP_ADMIN=true
SKEINRANK_GOVERNANCE_API_ADMIN_USERNAME=admin
SKEINRANK_GOVERNANCE_API_ADMIN_PASSWORD=change-me
SKEINRANK_GOVERNANCE_API_ENRICHMENT_JOBS_BACKEND=celery

# Agent container settings.
SKEINRANK_AGENT_API_URL=http://governance-api:8010
SKEINRANK_AGENT_ROLE=contributor
SKEINRANK_AGENT_API_TOKEN=CHANGE_ME_AGENT_CONTRIBUTOR_TOKEN

# Elasticsearch/OpenSearch validation index used only for the demo scenario.
SKEINRANK_DOCKER_DEMO_ELASTICSEARCH_URL=http://elasticsearch:9200
SKEINRANK_DOCKER_DEMO_ELASTICSEARCH_INDEX=skeinrank_agent_demo
SKEINRANK_DOCKER_DEMO_RESET_INDEX=true

# OpenRouter is disabled by default for the full Docker demo.
# Set SKEINRANK_DOCKER_DEMO_LIVE_LLM=true and provide OPENROUTER_API_KEY for a live LLM pass.
SKEINRANK_DOCKER_DEMO_LIVE_LLM=false
OPENROUTER_API_KEY=CHANGE_ME_OPENROUTER_KEY
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
SKEINRANK_DOCKER_DEMO_MAX_LLM_CALLS=3
SKEINRANK_DOCKER_DEMO_MAX_RUN_COST_USD=0.05

# Keep proposal submission disabled in the demo scenario.
SKEINRANK_AGENT_SUBMIT_PROPOSALS=false

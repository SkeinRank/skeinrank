# Copy to a local .env file or export these variables in your shell.
# Never commit real secrets.

SKEINRANK_AGENT_API_URL=http://127.0.0.1:8010
SKEINRANK_AGENT_ROLE=contributor
SKEINRANK_AGENT_SERVICE_ACCOUNT=openrouter-alias-scout
SKEINRANK_AGENT_API_TOKEN=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional Patch 40M local response cache controls.
# Values are normally read from agent_config.example.json; these are documented
# here so operators know not to commit generated cache files.
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Patch 40O Docker Compose deployment recipe uses deploy/docker/openrouter-alias-scout.env.example.
# The default Compose command writes an offline evaluation report; live LLM review
# should be enabled only with bounded budget settings and a real OpenRouter key.

# Optional Patch 41E Elasticsearch evidence connector.
# Used only when --sample-evidence-from-elasticsearch or
# --write-elasticsearch-evidence-records is requested.
ELASTICSEARCH_API_KEY=

{
  "skeinrank_api_url": "http://127.0.0.1:8010",
  "skeinrank_role": "contributor",
  "api_token_env": "SKEINRANK_AGENT_API_TOKEN",
  "openrouter_api_key_env": "OPENROUTER_API_KEY",
  "openrouter_base_url": "https://openrouter.ai/api/v1",
  "openrouter_app_title": "SkeinRank OpenRouter Alias Scout",
  "openrouter_http_referer": null,
  "openrouter_model": "openai/gpt-4o-mini",
  "default_profile_name": "infra_incidents",
  "default_binding_id": null,
  "proposal_source_name": "openrouter-alias-scout",
  "failed_queries_path": "failed_queries.example.jsonl",
  "max_queries_per_run": 25,
  "dry_run": true,
  "candidate_discovery": {
    "max_candidates": 20,
    "min_token_length": 2,
    "min_weighted_count": 1,
    "min_score": 1.0,
    "max_examples_per_candidate": 5,
    "known_terms": [
      "kubernetes",
      "postgresql",
      "postgres",
      "database",
      "production",
      "cluster"
    ],
    "noise_tokens": [
      "dns",
      "exhausted",
      "failover",
      "incident",
      "pod",
      "pool",
      "queue",
      "red",
      "restart",
      "rollout",
      "runbook",
      "shard",
      "stuck",
      "timeout",
      "worker"
    ],
    "stop_words": [
      "after",
      "during",
      "in",
      "the",
      "to",
      "with",
      "for",
      "and",
      "or"
    ]
  },
  "evidence_records_path": "evidence_records.example.jsonl",
  "evidence_sampler": {
    "max_records": 50,
    "max_docs": 5,
    "max_windows": 7,
    "window_chars": 90,
    "max_window_chars": 220,
    "max_total_chars": 1000,
    "text_fields": [
      "query",
      "snippet",
      "title",
      "text",
      "message",
      "content"
    ]
  },
  "demo_report": {
    "max_candidates_for_review": 5,
    "include_prompt_previews": false,
    "prompt_preview_chars": 800
  },
  "llm_review": {
    "max_candidates": 3,
    "min_confidence_to_prepare_proposal": 0.75,
    "temperature": 0.0,
    "max_tokens": 700,
    "include_tools": false,
    "response_format_json": true,
    "submit_proposals": false
  },
  "security_profile": {
    "service_account_name": "openrouter-alias-scout",
    "required_role": "contributor",
    "allowed_roles": [
      "contributor"
    ],
    "allow_proposal_submission": false,
    "allow_runtime_mutation": false,
    "require_skeinrank_api_token_for_submission": true,
    "blocked_actions": [
      "direct_dictionary_write",
      "snapshot_publish",
      "direct_git_push",
      "runtime_mutation"
    ],
    "allowed_skeinrank_tool_paths": [
      "GET /v1/tools/bindings",
      "POST /v1/tools/explain-query",
      "POST /v1/tools/validate-alias",
      "POST /v1/tools/suggest-alias"
    ],
    "redact_env_values": true
  },
  "budget_cache": {
    "max_llm_calls_per_run": 3,
    "max_total_tokens_per_run": 6000,
    "max_prompt_tokens_per_run": 5000,
    "max_cost_usd_per_run": 0.01,
    "cache_enabled": true,
    "cache_path": ".cache/openrouter_alias_scout_llm_cache.json",
    "cache_namespace": "openrouter-alias-scout-v1",
    "force_refresh": false,
    "write_cache": true
  },
  "evaluation_outcomes_path": "evaluation_outcomes.example.jsonl",
  "evaluation": {
    "min_confidence_for_review_ready": 0.75,
    "include_reviewed_items": true,
    "include_candidate_packs": false,
    "max_items": 50,
    "qrels_enabled": false,
    "snapshot_eval_enabled": false
  },
  "deployment": {
    "service_name": "openrouter-alias-scout",
    "image_name": "skeinrank/openrouter-alias-scout:local",
    "dockerfile_path": "deploy/docker/openrouter-alias-scout.Dockerfile",
    "compose_file_path": "deploy/docker/openrouter-alias-scout.compose.yml",
    "env_file_path": "deploy/docker/openrouter-alias-scout.env.example",
    "reports_dir": "examples/agents/openrouter_alias_scout/reports",
    "cache_dir": "examples/agents/openrouter_alias_scout/.cache",
    "default_mode": "evaluation_report",
    "schedule_mode": "manual",
    "schedule_cron": "0 2 * * *"
  },
  "canonical_hints": {
    "terms": [
      {
        "canonical_value": "kubernetes",
        "slot": "technology",
        "aliases": [
          "k8s",
          "kube",
          "kubectl"
        ],
        "tags": [
          "infra",
          "orchestration",
          "cloud-native"
        ],
        "description": "Container orchestration platform used in infra incidents."
      },
      {
        "canonical_value": "postgresql",
        "slot": "database",
        "aliases": [
          "pg",
          "postgres",
          "psql"
        ],
        "tags": [
          "database",
          "storage",
          "backend"
        ],
        "description": "PostgreSQL database and related operational runbooks."
      },
      {
        "canonical_value": "elasticsearch",
        "slot": "search_engine",
        "aliases": [
          "elastic",
          "es"
        ],
        "tags": [
          "search",
          "indexing"
        ],
        "description": "Elasticsearch search/indexing cluster terminology."
      },
      {
        "canonical_value": "rabbitmq",
        "slot": "queue",
        "aliases": [
          "rabbit",
          "amqp"
        ],
        "tags": [
          "messaging",
          "broker"
        ],
        "description": "RabbitMQ message broker and queue incidents."
      }
    ],
    "known_conflicts": {
      "pg": [
        "page",
        "product_group"
      ],
      "es": [
        "ecmascript",
        "spanish_language"
      ],
      "rabbit": [
        "animal_common_word"
      ]
    },
    "max_known_canonicals_in_pack": 20
  },
  "proposal_submission": {
    "max_proposals_per_run": 5,
    "min_confidence": 0.85,
    "require_validation_status": "passed",
    "submit_enabled": false,
    "stop_on_error": false,
    "treat_existing_alias_as_idempotent": true,
    "manual_review_on_warning": true
  }
}

{
  "agent_tracking": {
    "agent_name": "openrouter-alias-scout",
    "agent_version": "openrouter-alias-scout",
    "content_fields": [
      "query",
      "title",
      "text",
      "message",
      "content",
      "body",
      "snippet"
    ],
    "enabled": true,
    "include_record_previews": false,
    "ledger_path": ".cache/openrouter_alias_scout_run_ledger.jsonl",
    "max_recent_ledger_entries": 10000,
    "preview_chars": 160,
    "prompt_version": "canonical-hints-v1",
    "skip_unchanged_documents": true,
    "source_id_fields": [
      "id",
      "source_id",
      "doc_id",
      "document_id",
      "trace_id"
    ]
  },
  "api_token_env": "SKEINRANK_AGENT_API_TOKEN",
  "approved_apply": {
    "after_snapshot_path": null,
    "approved_statuses": [
      "approved"
    ],
    "before_snapshot_path": null,
    "include_item_details": true,
    "max_items": 50
  },
  "artifact_standard": {
    "include_checksums": true,
    "layout_version": "skeinrank.agent_artifacts_layout.v1",
    "manifest_filename": "manifest.json",
    "reports_subdir": "reports",
    "root_dir": "reports",
    "summary_filename": "run_summary.json",
    "write_manifest": true
  },
  "budget_cache": {
    "cache_enabled": true,
    "cache_namespace": "openrouter-alias-scout-v1",
    "cache_path": ".cache/openrouter_alias_scout_llm_cache.json",
    "force_refresh": false,
    "max_cost_usd_per_run": 0.01,
    "max_llm_calls_per_run": 3,
    "max_prompt_tokens_per_run": 5000,
    "max_total_tokens_per_run": 6000,
    "write_cache": true
  },
  "candidate_discovery": {
    "known_terms": [
      "kubernetes",
      "postgresql",
      "postgres",
      "database",
      "production",
      "cluster"
    ],
    "max_candidates": 20,
    "max_examples_per_candidate": 5,
    "min_score": 1.0,
    "min_token_length": 2,
    "min_weighted_count": 1,
    "noise_tokens": [
      "dns",
      "exhausted",
      "failover",
      "incident",
      "pod",
      "pool",
      "queue",
      "red",
      "restart",
      "rollout",
      "runbook",
      "shard",
      "stuck",
      "timeout",
      "worker"
    ],
    "stop_words": [
      "after",
      "during",
      "in",
      "the",
      "to",
      "with",
      "for",
      "and",
      "or"
    ],
    "include_code_style_candidates": true,
    "include_phrase_candidates": true,
    "max_phrase_terms": 3
  },
  "canonical_hints": {
    "known_conflicts": {
      "es": [
        "ecmascript",
        "spanish_language"
      ],
      "pg": [
        "page",
        "product_group"
      ],
      "rabbit": [
        "animal_common_word"
      ]
    },
    "max_known_canonicals_in_pack": 20,
    "terms": [
      {
        "aliases": [
          "k8s",
          "kube",
          "kubectl"
        ],
        "canonical_value": "kubernetes",
        "description": "Container orchestration platform used in infra incidents.",
        "slot": "technology",
        "tags": [
          "infra",
          "orchestration",
          "cloud-native"
        ]
      },
      {
        "aliases": [
          "pg",
          "postgres",
          "psql"
        ],
        "canonical_value": "postgresql",
        "description": "PostgreSQL database and related operational runbooks.",
        "slot": "database",
        "tags": [
          "database",
          "storage",
          "backend"
        ]
      },
      {
        "aliases": [
          "elastic",
          "es"
        ],
        "canonical_value": "elasticsearch",
        "description": "Elasticsearch search/indexing cluster terminology.",
        "slot": "search_engine",
        "tags": [
          "search",
          "indexing"
        ]
      },
      {
        "aliases": [
          "rabbit",
          "amqp"
        ],
        "canonical_value": "rabbitmq",
        "description": "RabbitMQ message broker and queue incidents.",
        "slot": "queue",
        "tags": [
          "messaging",
          "broker"
        ]
      }
    ]
  },
  "default_binding_id": null,
  "default_profile_name": "infra_incidents",

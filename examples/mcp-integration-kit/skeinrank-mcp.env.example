SKEINRANK_MCP_GOVERNANCE_API_URL=http://127.0.0.1:8010
# Local no-auth development may keep admin.
# Auth-enabled deployments should prefer contributor + scoped service-account token.
SKEINRANK_MCP_ROLE=contributor
SKEINRANK_MCP_TIMEOUT_SECONDS=10.0
# SKEINRANK_MCP_API_TOKEN=paste-scoped-service-account-token-here

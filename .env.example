# SkeinRank Docker Compose development defaults.
# Copy to .env before running docker-compose.dev.yml.

TZ=UTC

# Published local ports
GOVERNANCE_API_PORT=8010
UI_PORT=5173
POSTGRES_PORT=15432
ELASTICSEARCH_PORT=19200
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318

# Datastores
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=skeinrank_dev_password
RABBITMQ_DEFAULT_USER=skeinrank
RABBITMQ_DEFAULT_PASS=skeinrank_dev_password
ES_JAVA_OPTS=-Xms512m -Xmx512m

# Governance API
SKEINRANK_GOVERNANCE_API_AUTH_ENABLED=true
SKEINRANK_GOVERNANCE_API_BOOTSTRAP_ADMIN=true
SKEINRANK_GOVERNANCE_API_ADMIN_USERNAME=admin
SKEINRANK_GOVERNANCE_API_ADMIN_PASSWORD=change-me
SKEINRANK_GOVERNANCE_API_ADMIN_DISPLAY_NAME=SkeinRank Admin
SKEINRANK_GOVERNANCE_API_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
SKEINRANK_GOVERNANCE_API_ENRICHMENT_JOBS_BACKEND=celery
SKEINRANK_GOVERNANCE_API_CELERY_TASK_QUEUE=skeinrank.enrichment
SKEINRANK_GOVERNANCE_API_ENRICHMENT_CHUNK_SIZE=500

# Observability
SKEINRANK_GOVERNANCE_API_OBSERVABILITY_ENABLED=true
SKEINRANK_GOVERNANCE_API_LOG_FORMAT=json
SKEINRANK_GOVERNANCE_API_LOG_LEVEL=info
SKEINRANK_GOVERNANCE_API_ACCESS_LOG_ENABLED=true
SKEINRANK_GOVERNANCE_API_REQUEST_ID_HEADER=X-Request-ID
SKEINRANK_GOVERNANCE_API_METRICS_ENABLED=true
SKEINRANK_GOVERNANCE_API_METRICS_PATH=/metrics
SKEINRANK_GOVERNANCE_API_TRACING_ENABLED=false
SKEINRANK_GOVERNANCE_API_OTEL_SERVICE_NAME=skeinrank-governance-api
SKEINRANK_GOVERNANCE_API_OTEL_TRACES_EXPORTER=none
SKEINRANK_GOVERNANCE_API_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
SKEINRANK_GOVERNANCE_API_OTEL_SAMPLING_RATIO=1.0
SKEINRANK_GOVERNANCE_API_OTEL_CAPTURE_QUERY_TEXT=false

# UI
VITE_SKEINRANK_GOVERNANCE_API_URL=http://127.0.0.1:8010

# Grafana dev login
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
